```gitignore
# Python compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Test files
tests/__pycache__/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Dependencies
venv/
.venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Coverage reports
.coverage
coverage/
htmlcov/

# Temporary files
*.tmp
*.temp

# OS files
.DS_Store
Thumbs.db
```