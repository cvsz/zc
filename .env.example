# AI Model Coder CLI — environment configuration
# Copy this file to .env and fill in your keys.

# Required for all zAICoder API features.
ANTHROPIC_ADMIN_API_KEY=
# LiteLLM Proxy configuration
LITELLM_MASTER_KEY=sk-litellm-master-key
ANTHROPIC_BASE_URL=http://localhost:4000
ANTHROPIC_API_KEY=

# Optional: Add other provider keys if routing via LiteLLM
OPENAI_API_KEY=
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

HF_TOKEN_API_KEY=
HF_URL=https://router.huggingface.co/v1

OPENROUTER_ZBOT_API_KEY=
OPENROUTER_ZMANAGE_API_KEY=

NOVITA_API_KEY=

OPENCODE_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_API_KEY=

# Optional. Only needed for --embed / --embed-file / --embed-similarity
# (zc_embeddings.py). Anthropic does not host its own embedding model;
# these commands call Voyage AI, Anthropic's documented embeddings partner.
# Get a key at https://dashboard.voyageai.com
VOYAGE_API_KEY=

# Optional. Only needed if you use --gh-* (zc_github.py) commands.
GH_TOKEN=
