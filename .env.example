# Local development profile for the canonical standalone zc runtime.
# Copy to .env. Never commit the populated file.

ENVIRONMENT=development
DEBUG=true
AUTH_REQUIRED=false
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=1
API_TIMEOUT=30
HTTP_POOL_SIZE=20

AI_PROVIDER=litellm
LITELLM_CONFIG_PATH=./litellm-config.yaml
LITELLM_MODEL=zc-default
LITELLM_TIMEOUT_SECONDS=120
ANTHROPIC_API_KEY=

STORAGE_BACKEND=local
UPLOAD_TEMP_DIR=./data/uploads
UPLOAD_CHUNK_SIZE=4194304
UPLOAD_MAX_SIZE=53687091200
UPLOAD_RETENTION_SECONDS=86400
UPLOAD_MIN_FREE_BYTES=1073741824
MAX_MESSAGE_SIZE=94371840
IDEMPOTENCY_DIR=./data/idempotency
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_MAX_RESPONSE_BYTES=1048576
IDEMPOTENCY_MAX_ENTRIES=1000
CHAT_SESSION_DIR=./data/chat/sessions

REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_POOL_SIZE=10
REDIS_TTL_DEFAULT=3600
PROTOBUF_ENABLED=false
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60
STRICT_READINESS=false
CONTROL_PANEL_ENABLED=true
FRONTEND_ENABLED=true
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

CLOUDFLARE_ACCESS_REQUIRED=false
CLOUDFLARE_ACCESS_TEAM_DOMAIN=
CLOUDFLARE_ACCESS_AUD=
CLOUDFLARE_ACCESS_JWKS_CACHE_SECONDS=300

JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ISSUER=zc
JWT_AUDIENCE=zc-api
JWT_EXPIRY_SECONDS=3600
E2E_SECRET_KEY=

# Thin compatibility CLI client credentials.
ZC_API_URL=http://127.0.0.1:8000
ZC_API_TOKEN=
